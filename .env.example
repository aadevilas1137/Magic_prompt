# =============================================================================
# Magic Prompt AI — root .env.example (documentation)
# =============================================================================
# Copy to .env.local inside apps/web for local development.
# Validation lives in apps/web/src/lib/env.ts (Zod). Build will fail if any
# required variable is missing or malformed.
# -----------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ----------------------------------------------------------------
# Project URL and keys from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (Drizzle migrations + server runtime)
DATABASE_URL=

# --- OpenAI (Phase 4+, optional in Phase 1) ----------------------------------
OPENAI_API_KEY=

# --- Sentry (optional in dev) ------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog (optional in dev) -----------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
