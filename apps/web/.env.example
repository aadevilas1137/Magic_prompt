# Copy to .env.local and fill the values you have.
# Validation: src/lib/env.ts (Zod). Build fails if a required value is malformed.

# --- App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (optional in Phase 1; required from Phase 2 onward)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection used by the app at RUNTIME.
# OK to use the Transaction pooler (port 6543) — multiplexes ephemeral
# connections cheaply, ideal for serverless / Next.js.
DATABASE_URL=
# Optional: separate Postgres connection used ONLY by drizzle-kit
# (`db:generate`, `db:migrate`, `db:push`, `db:studio`). Use the Session
# pooler OR Direct connection (port 5432) — they support prepared statements
# and DDL-in-transactions, which the transaction pooler does NOT. If unset,
# drizzle-kit falls back to DATABASE_URL.
MIGRATE_DATABASE_URL=

# --- OpenAI (REQUIRED from Phase 3 onward — chat won't function without it)
# Get a key from https://platform.openai.com/api-keys. Both classic `sk-…`
# keys and project-scoped `sk-proj-…` keys work. The env validator enforces
# `startsWith('sk-')` + length ≥ 20.
OPENAI_API_KEY=
# Models. Override the defaults if you want to A/B between gpt-4o /
# gpt-4-turbo / gpt-3.5-turbo etc. Title model uses a cheaper tier.
OPENAI_MODEL=gpt-4o
OPENAI_TITLE_MODEL=gpt-4o-mini

# --- Chat tuning
# Last N persisted messages sent to the LLM as context. Higher = better
# memory, more tokens (cost + latency). Practical range: 10–40.
CHAT_CONTEXT_WINDOW=20
# Maximum characters in a single user message (defence against runaway
# pastes; the LLM has its own context-window enforcement upstream).
CHAT_MAX_MESSAGE_LENGTH=8000

# --- IPE — Invisible Prompt Engine (Phase 4)
# Master switch. When false (default), /api/chat behaves identically to Phase 3:
# raw LLM, static system prompt. Set to true to enable the 5-layer pipeline.
IPE_ENABLED=false
# If IPE throws, fall back to Phase 3 raw-LLM path so users still get a response.
# Turn off only when debugging.
IPE_FALLBACK_ON_ERROR=true
# Per-layer timeouts (milliseconds). Both layers hit gpt-4o-mini; 2s is generous.
IPE_INTENT_TIMEOUT_MS=2000
IPE_CLASSIFIER_TIMEOUT_MS=2000
# Layer 5 LLM-as-judge sampling rate (0-1). 0.1 = 10% of responses get sampled.
IPE_QUALITY_SAMPLE_RATE=0.1
# Enables the `?showMagic=1` debug panel. Still gated by admin-email check.
IPE_DEBUG_MODE=false
# Pipeline schema version stamped on every prompt_logs row.
IPE_PIPELINE_VERSION=v1
# Comma-separated admin email list — gates `?showMagic=1`. Defaults to the
# project owner; extend (e.g. team review). Empty = no one (production hardening).
IPE_ADMIN_EMAILS=aadevilasrao1137@gmail.com

# --- Sentry (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog (optional in dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Logging
LOG_LEVEL=info
