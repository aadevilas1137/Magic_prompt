# Copy to .env.local and fill the values you have.
# Validation: src/lib/env.ts (Zod). Build fails if a required value is malformed.

# --- App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (optional in Phase 1; required from Phase 2 onward)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- OpenAI (required from Phase 4 onward)
OPENAI_API_KEY=

# --- Sentry (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog (optional in dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Logging
LOG_LEVEL=info
