# Copy to .env.local and fill the values you have.
# Validation: src/lib/env.ts (Zod). Build fails if a required value is malformed.

# --- App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (optional in Phase 1; required from Phase 2 onward)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection used by the app at RUNTIME.
# OK to use the Transaction pooler (port 6543) — multiplexes ephemeral
# connections cheaply, ideal for serverless / Next.js.
DATABASE_URL=
# Optional: separate Postgres connection used ONLY by drizzle-kit
# (`db:generate`, `db:migrate`, `db:push`, `db:studio`). Use the Session
# pooler OR Direct connection (port 5432) — they support prepared statements
# and DDL-in-transactions, which the transaction pooler does NOT. If unset,
# drizzle-kit falls back to DATABASE_URL.
MIGRATE_DATABASE_URL=

# --- OpenAI (required from Phase 4 onward)
OPENAI_API_KEY=

# --- Sentry (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog (optional in dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Logging
LOG_LEVEL=info
