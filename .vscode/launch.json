{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Next.js: debug server-side (attach)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Vitest: current file",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@magic-prompt/web", "exec", "vitest", "run", "${relativeFile}"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Vitest: all",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@magic-prompt/web", "exec", "vitest", "run"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/web"
    }
  ]
}
